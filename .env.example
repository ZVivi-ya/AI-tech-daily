# ════════════════════════════════════════
# AI科技早报 - 环境配置模板
# 使用前请复制为 .env 并填入真实值
# ════════════════════════════════════════

# ─── DeepSeek API ───
# 获取地址：https://platform.deepseek.com/api_keys
DEEPS_API_KEY=your_deepseek_api_key_here
DEEPS_BASE_URL=https://api.deepseek.com/v1

# ─── 微信公众号 ───
# 在微信公众平台 → 开发 → 基本配置 中获取
WX_APPID=your_appid_here
WX_APPSECRET=your_appsecret_here

# ─── 封面图素材 media_id ───
# 在微信公众平台 → 素材管理 → 上传图片，获取 media_id
# 若未配置，将在 HTML 中用占位图替代
THUMB_MEDIA_ID=
